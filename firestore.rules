// RAPPI TEAM - Firestore Security Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isAuthenticated() && getUserId() == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data;
    }

    function userExists() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(getUserId()));
    }

    // Role checks: support both 'role' and 'userType' fields, plus 'dual' accounts
    function isAdmin() {
      return userExists() && (
        getUserData().userType == 'admin' ||
        getUserData().role == 'admin' ||
        getUserData().isAdmin == true
      );
    }

    function isDriver() {
      return userExists() && (
        getUserData().userType == 'driver' ||
        getUserData().userType == 'dual' ||
        getUserData().role == 'driver' ||
        getUserData().currentMode == 'driver' ||
        ('availableRoles' in getUserData() && 'driver' in getUserData().availableRoles)
      );
    }

    function isPassenger() {
      return userExists() && (
        getUserData().userType == 'passenger' ||
        getUserData().userType == 'dual' ||
        getUserData().role == 'passenger' ||
        getUserData().currentMode == 'passenger' ||
        ('availableRoles' in getUserData() && 'passenger' in getUserData().availableRoles)
      );
    }

    function isDriverOrPassenger() {
      return isDriver() || isPassenger();
    }

    function isActiveUser() {
      return userExists() && getUserData().isActive == true;
    }

    // ═══════════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin() ||
        (isDriverOrPassenger() && resource.data.isActive == true)
      );
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (
        (isOwner(userId) &&
         !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys())) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // DRIVERS (main driver collection used by the app)
    // ═══════════════════════════════════════════════

    match /drivers/{driverId} {
      allow read: if isAuthenticated() && (
        isOwner(driverId) ||
        isAdmin() ||
        isPassenger()
      );
      allow create: if isAuthenticated() && isOwner(driverId);
      allow update: if isAuthenticated() && (
        isOwner(driverId) || isAdmin()
      );
      allow delete: if isAdmin();

      // Driver documents subcollection (verification documents)
      match /documents/{docId} {
        allow read: if isAuthenticated() && (
          isOwner(driverId) || isAdmin()
        );
        allow create: if isAuthenticated() && isOwner(driverId);
        allow update: if isAuthenticated() && (
          isOwner(driverId) || isAdmin()
        );
        allow delete: if isAdmin();
      }

      // Vehicle subcollection
      match /vehicle/{vehicleId} {
        allow read: if isAuthenticated() && (
          isOwner(driverId) || isAdmin() || isPassenger()
        );
        allow create, update: if isAuthenticated() && (
          isOwner(driverId) || isAdmin()
        );
        allow delete: if isAdmin();
      }
    }

    // Driver profiles (legacy, kept for backward compat)
    match /driver_profiles/{driverId} {
      allow read: if isAuthenticated() && (
        isOwner(driverId) || isAdmin() || isPassenger()
      );
      allow create: if isAuthenticated() && isOwner(driverId);
      allow update: if isAuthenticated() && (
        isOwner(driverId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Driver locations (real-time GPS)
    match /driver_locations/{driverId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isDriver() && isOwner(driverId);
      allow update: if isAuthenticated() && isDriver() && isOwner(driverId);
      allow delete: if isAuthenticated() && (isOwner(driverId) || isAdmin());
    }

    // ═══════════════════════════════════════════════
    // RIDES
    // ═══════════════════════════════════════════════

    match /rides/{rideId} {
      // Support both passengerId and userId fields for backward compatibility
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isOwner(resource.data.passengerId) ||
        isOwner(resource.data.userId) ||
        isOwner(resource.data.driverId) ||
        (isDriver() && resource.data.status in [
          'searching', 'requested', 'searching_driver',
          'pending', 'waiting_driver', 'accepted', 'negotiating'
        ])
      );

      allow create: if isAuthenticated() && (isPassenger() || isDriver());

      allow update: if isAuthenticated() && (
        isOwner(resource.data.passengerId) ||
        isOwner(resource.data.userId) ||
        isOwner(resource.data.driverId) ||
        isDriver() ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // NEGOTIATIONS (InDriver-style price negotiation)
    // ═══════════════════════════════════════════════

    match /negotiations/{negotiationId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isOwner(resource.data.passengerId) ||
        isOwner(resource.data.driverId) ||
        isDriver()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.passengerId) ||
        isOwner(resource.data.driverId) ||
        isDriver() ||
        isAdmin()
      );
      allow delete: if isAdmin();

      // Offers subcollection within negotiations
      match /offers/{offerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
      }
    }

    // ═══════════════════════════════════════════════
    // SETTINGS & CONFIG
    // ═══════════════════════════════════════════════

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /system_config/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // Maintenance mode (readable by all)
    match /maintenance_mode/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }

    // ═══════════════════════════════════════════════
    // PAYMENTS & WALLETS
    // ═══════════════════════════════════════════════

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isOwner(resource.data.userId)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // wallet (singular) - some code uses this
    match /wallet/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /walletTransactions/{txId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) ||
        isOwner(resource.data.walletId) ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /paymentMethods/{methodId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
    }

    match /payment_methods/{methodId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
    }

    // ═══════════════════════════════════════════════
    // DRIVER CREDITS & EARNINGS
    // ═══════════════════════════════════════════════

    match /driver_credits/{driverId} {
      allow read: if isAuthenticated() && (
        isOwner(driverId) || isAdmin()
      );
      allow write: if isAuthenticated() && (
        isOwner(driverId) || isAdmin()
      );
    }

    match /creditTransactions/{txId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /credit_transactions/{txId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /driver_earnings/{driverId} {
      allow read: if isAuthenticated() && (
        isOwner(driverId) || isAdmin()
      );
      allow write: if false; // Only backend
    }

    match /driver_payouts/{payoutId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow create: if isAuthenticated() && isDriver() && isOwner(resource.data.driverId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow create: if isAuthenticated() && isDriver();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow create: if isAuthenticated() && isDriver();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow create: if isAuthenticated() && isDriver();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // CHAT & CONVERSATIONS
    // ═══════════════════════════════════════════════

    match /conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
      }
    }

    // Legacy chat_messages (flat collection)
    match /chat_messages/{messageId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.senderId) ||
        isOwner(resource.data.receiverId) ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.senderId);
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.senderId) || isAdmin()
      );
    }

    // ═══════════════════════════════════════════════
    // NOTIFICATIONS
    // ═══════════════════════════════════════════════

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if false; // Only backend
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
    }

    match /admin_notifications/{notifId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // VEHICLES
    // ═══════════════════════════════════════════════

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isDriver();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // RATINGS & REVIEWS
    // ═══════════════════════════════════════════════

    match /ratings/{ratingId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isOwner(resource.data.userId) ||
        isOwner(resource.data.driverId)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // USER PREFERENCES & DEVICE TOKENS
    // ═══════════════════════════════════════════════

    match /user_preferences/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /user_notification_preferences/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /user_device_tokens/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /user_topic_subscriptions/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /user_stats/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow write: if false; // Only backend
    }

    match /achievements/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend
    }

    // ═══════════════════════════════════════════════
    // EMERGENCY
    // ═══════════════════════════════════════════════

    match /emergencyContacts/{contactId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
    }

    match /emergency_contacts/{contactId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
    }

    match /emergencyAlerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /emergencies/{emergencyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /emergency_calls/{callId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /sharedLocations/{locId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════
    // SUPPORT & REPORTS
    // ═══════════════════════════════════════════════

    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // App uses camelCase version too
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /userReports/{reportId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // PROMOTIONS
    // ═══════════════════════════════════════════════

    match /promotions/{promotionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /used_promotions/{promoId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // SHIFTS (driver schedules)
    // ═══════════════════════════════════════════════

    match /shifts/{shiftId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isOwner(resource.data.driverId)
      );
      allow create: if isAuthenticated() && isDriver();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
    }

    match /shift_templates/{templateId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isOwner(resource.data.driverId)
      );
      allow create: if isAuthenticated() && isDriver();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.driverId) || isAdmin()
      );
    }

    // ═══════════════════════════════════════════════
    // SECURITY & LOGS
    // ═══════════════════════════════════════════════

    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════
    // ANALYTICS (read-only, backend writes)
    // ═══════════════════════════════════════════════

    match /daily_analytics/{date} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /user_analytics/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow write: if false;
    }

    match /driver_analytics/{driverId} {
      allow read: if isAuthenticated() && (
        isOwner(driverId) || isAdmin()
      );
      allow write: if false;
    }

    match /user_notification_stats/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if false;
    }

    // ═══════════════════════════════════════════════
    // ARCHIVED DATA (admin only, backend writes)
    // ═══════════════════════════════════════════════

    match /archived_payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /archived_rides/{rideId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /payment_reconciliation/{date} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
