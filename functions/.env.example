# ============================================================================
# 🔐 VARIABLES DE ENTORNO - RAPITEAM CLOUD FUNCTIONS
# ============================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como '.env' en la misma carpeta (functions/)
# 2. Completa los valores con tus credenciales reales
# 3. NUNCA commitees el archivo .env real (está en .gitignore)
# 4. Para producción, usa: firebase functions:config:set
#
# ============================================================================

# 💳 CULQI - PASARELA DE PAGOS PERUANA (PRINCIPAL)
# ============================================================================
# Obtén tus credenciales en: https://panel.culqi.com > Desarrollo > API Keys
#
# ⚠️ IMPORTANTE:
# - Public Key (pk_test_/pk_live_) es SEGURA para el cliente
# - Private Key (sk_test_/sk_live_) es PRIVADA y SOLO debe estar en el backend

# Public Key - Se envía al cliente para el Custom Checkout
CULQI_PUBLIC_KEY=pk_test_e94078b9d4c5b786

# Private Key - PRIVADA - Para procesar cargos en el backend
CULQI_PRIVATE_KEY=sk_test_XXXXXXXXXXXXXXXX

# ============================================================================
# 🔧 CULQI - CONFIGURACIÓN PARA PRODUCCIÓN
# ============================================================================
# Para producción, usa credenciales de LIVE:
# CULQI_PUBLIC_KEY=pk_live_XXXXXXXXXXXXXXXX
# CULQI_PRIVATE_KEY=sk_live_XXXXXXXXXXXXXXXX

# ============================================================================
# 💳 MERCADOPAGO - PERÚ (DEPRECADO - Solo para compatibilidad)
# ============================================================================
# Obtén tus credenciales en: https://www.mercadopago.com.pe/developers/panel/credentials
#
# ⚠️ IMPORTANTE:
# - Public Key (APP_USR-...) es SEGURA para el cliente
# - Access Token es PRIVADA y SOLO debe estar en el backend
# - Webhook Secret se obtiene al crear el webhook en el panel

# Public Key (para checkout en la app)
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Access Token (PRIVADA - para procesar pagos en el backend)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook Secret (para validar webhooks)
MERCADOPAGO_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# 🔧 CONFIGURACIÓN PARA DESARROLLO LOCAL
# ============================================================================
# Para desarrollo local, usa credenciales de TEST:
# CULQI_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXX
# CULQI_PRIVATE_KEY=sk_test_XXXXXXXXXXXXXXXX
# MERCADOPAGO_PUBLIC_KEY=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# 📝 NOTAS DE SEGURIDAD
# ============================================================================
# 1. La Public Key se envía al cliente mediante el endpoint /getCulqiConfig
# 2. La Private Key NUNCA sale del backend
# 3. En producción, configura con:
#    firebase functions:config:set culqi.public_key="pk_live_..."
#    firebase functions:config:set culqi.private_key="sk_live_..."
