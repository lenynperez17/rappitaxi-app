# ============================================================================
# VARIABLES DE ENTORNO - RAPPI TEAM CLOUD FUNCTIONS
# ============================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como '.env' en la misma carpeta (functions/)
# 2. Completa los valores con tus credenciales reales
# 3. NUNCA commitees el archivo .env real (esta en .gitignore)
# 4. Para produccion, usa: firebase functions:config:set
#
# ============================================================================

# MERCADOPAGO - PERU
# ============================================================================
# Obtener credenciales en: https://www.mercadopago.com.pe/developers/panel/credentials
#
# IMPORTANTE:
# - Public Key (APP_USR-...) es SEGURA para el cliente
# - Access Token es PRIVADA y SOLO debe estar en el backend
# - Webhook Secret se obtiene al crear el webhook en el panel

# Public Key (para checkout en la app)
MERCADOPAGO_PUBLIC_KEY=APP_USR-8fdfa894-9849-4670-ae6a-4581c14e91c1

# Access Token (PRIVADA - para procesar pagos en el backend)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-970812101840504-022821-e5a44e79d3dd5c1042e9df0653d0ced5-3226711346

# Client ID y Secret
MERCADOPAGO_CLIENT_ID=970812101840504
MERCADOPAGO_CLIENT_SECRET=NcHlgyRmV7BKU6zU6gbBqu6mnliFimEO

# Webhook Secret (para validar webhooks)
MERCADOPAGO_WEBHOOK_SECRET=rappi_team_webhook_secret_2024

# ============================================================================
# CONFIGURACION FIREBASE FUNCTIONS
# ============================================================================
FUNCTIONS_URL=https://us-central1-rapi-team.cloudfunctions.net

# ============================================================================
# CONFIGURACION PARA DESARROLLO LOCAL
# ============================================================================
# Para desarrollo local, usa credenciales de TEST:
# MERCADOPAGO_PUBLIC_KEY=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# NOTAS DE SEGURIDAD
# ============================================================================
# 1. La Public Key se envia al cliente mediante el endpoint /getMercadoPagoConfig
# 2. El Access Token NUNCA sale del backend
# 3. El Webhook Secret valida que los webhooks vengan de MercadoPago real
# 4. En produccion, configura con:
#    firebase functions:config:set mercadopago.public_key="APP_USR-..."
#    firebase functions:config:set mercadopago.access_token="APP_USR-..."
#    firebase functions:config:set mercadopago.webhook_secret="..."
