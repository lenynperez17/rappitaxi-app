# Archivo de ejemplo de configuración de entorno - RappiTaxi
# Copia este archivo a .env y completa con valores reales

# Entorno
NODE_ENV=development
FLUTTER_ENV=development

# API URLs
API_BASE_URL=http://localhost:3000/api/v1
SOCKET_URL=ws://localhost:3000
WEB_URL=http://localhost:3000

# Firebase Configuration
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_API_KEY=tu-api-key-firebase
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
FIREBASE_APP_ID=tu-app-id

# Google Services
GOOGLE_MAPS_API_KEY=tu-google-maps-api-key
GOOGLE_PLACES_API_KEY=tu-google-places-api-key

# MercadoPago Configuration
MERCADOPAGO_PUBLIC_KEY=tu-mercadopago-public-key
MERCADOPAGO_ACCESS_TOKEN=tu-mercadopago-access-token

# OneSignal Push Notifications
ONESIGNAL_APP_ID=tu-onesignal-app-id

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/rappitaxi_dev
MONGODB_URL=mongodb://localhost:27017/rappitaxi_dev

# JWT Configuration
JWT_SECRET=tu-jwt-secret
JWT_EXPIRES_IN=7d

# Email Configuration
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=tu-usuario-smtp
SMTP_PASS=tu-password-smtp

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug

# Features Flags
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_REMOTE_CONFIG=true

# Tarifa base
BASE_FARE=3.50
PRICE_PER_KM=1.20
PRICE_PER_MINUTE=0.15

# Configuración de la aplicación
MIN_ANDROID_VERSION=21
MIN_IOS_VERSION=12.0
FORCE_UPDATE_VERSION=1.0.0

# Debug
DEBUG=true
VERBOSE_LOGGING=true
